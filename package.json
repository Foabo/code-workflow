{
  "name": "flowflow",
  "version": "0.1.0",
  "description": "Flowflow workflow kernel for coding harnesses.",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "bin": {
    "ff": "./dist/src/cli.js",
    "ff-work": "./dist/src/agent-command.js",
    "ff-clarify": "./dist/src/agent-command.js",
    "ff-plan": "./dist/src/agent-command.js",
    "ff-run": "./dist/src/agent-command.js",
    "ff-check": "./dist/src/agent-command.js",
    "ff-finish": "./dist/src/agent-command.js",
    "ff-resume": "./dist/src/agent-command.js",
    "ff-discard": "./dist/src/agent-command.js",
    "ff-doctor": "./dist/src/agent-command.js",
    "ff-understand": "./dist/src/agent-command.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "rm -rf dist && npm run build && node --test $(find dist/tests -name '*.test.js' -type f | sort)",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md",
    "DESIGN.md",
    "CONTEXT.md",
    "docs/adr"
  ],
  "devDependencies": {
    "@types/node": "^20.14.11",
    "typescript": "^5.5.3"
  }
}
